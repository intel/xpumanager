    x.align="l"
    print(x)


def get_frequency(deviceId, realtime=False):
    data = get_measurement(deviceId, "frequency", realtime)

    x = PrettyTable()

    x.field_names = ["Frequency", "Value(MHz)"]
    for k,v in data['frequency'].items():
        x.add_row([k,v])
    
    x.align="l"
    print(x)


def get_measurement(deviceId, measurementType, realtime=False):
    url = "/dgm/v1/devices/{}/measurements".format(deviceId)
    params = {"type": measurementType}
    if realtime:
        params['realtime'] = True
    res = requests.get(host + url, params=params)
    if res.status_code != 200:
        print("Error occurs:"+res.content.decode())
        return
    return res.json()


if __name__ == "__main__":
    arg()
