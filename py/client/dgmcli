#!/usr/bin/python3
import argparse

import json

import pprint
import requests

# from texttable import Texttable
from prettytable import PrettyTable

import os

os.environ['NO_PROXY'] = 'localhost'

host = "http://localhost:5000"

parser = argparse.ArgumentParser()
parser.add_argument('-l', '--list', action='store_true',
                    help='list all device')
parser.add_argument('-i', '--immed', action='store_true',
                    help='get realtime measuring data')
parser.add_argument('-d', '--device', help='specify a device by `GPU ID`')
parser.add_argument('-f', '--freq', action='store_true',
                    help='get latest frequency of gpu')
parser.add_argument('-p', '--power', action='store_true',
                    help='get latest power of gpu')
parser.add_argument('-t', '--temp', action='store_true',
                    help='get latest temperature of gpu')


def arg():
    parsed = parser.parse_args()
    # print(parsed)
    if parsed.list:
        get_devices()
        return
    if parsed.freq:
        if parsed.device:
            get_frequency(parsed.device, parsed.immed)
        else:
            print("Param error: device_id need be specified")
        return
    if parsed.power:
        if parsed.device:
            get_power(parsed.device, parsed.immed)
        else:
            print("Param error: device_id need be specified")
        return
    if parsed.temp:
        if parsed.device:
            get_temp(parsed.device, parsed.immed)
        else:
            print("Param error: device_id need be specified")
        return
    
    parser.print_help()


def device_info_to_str(props):
    info_list = []
    order_list = [
        "Device Type","Device Name","Brand Name","Serial Number","Vendor Name","UUID","PCI BDF address",None,
        "Driver Version", "Firmware Name","Firmware Version",None,
        "Memory Physical Size",None,
        "Core Clock Rate", "available frequency", None,
        "Number of Slices","Number of Sub Slices Per Sub Slice","Number of EUs Per Sub Slice"
    ]
    for k in order_list:
        if k is None:
            info_list.append("")
        elif k in props.keys():
            info_list.append(k+": "+props[k])
    return "\n".join(info_list)

def get_devices():
    res = requests.get(host+"/dgm/v1/devices")

    if res.status_code != 200:
        print("Error occurs:"+res.content.decode())
        return

    data = res.json()

    for gpu in data:
        # print("GPU", gpu['device_id'])
        x = PrettyTable()

        props = dict()

        for p in gpu['properties']:
            for k, v in p.items():
                props[k]=v
        
        x.field_names = ["GPU ID", "Device Information"]
        x.add_row([gpu['device_id'],device_info_to_str(props)])

        x.align="l"
        print(x)


def get_temp(deviceId, realtime=False):
    data = get_measurement(deviceId, "temp", realtime)

    x = PrettyTable()

    x.field_names = ["Temp", "Value(°C)"]
    for k,v in data['temp'].items():
        x.add_row([k,v])
    
    x.align="l"
    print(x)

def get_power(deviceId, realtime=False):
    data = get_measurement(deviceId, "power", realtime)

    x = PrettyTable()

    x.field_names = ["Power", "Value(W)"]
    for k,v in data['power'].items():
