def search_engine_type_enum(num):
    return {
        1 << 0: "XPUM_UNDEFINED",
        1 << 1: "XPUM_COMPUTE",
        1 << 2: "XPUM_THREE_D",
        1 << 3: "XPUM_MEDIA",
        1 << 4: "XPUM_COPY",
        1 << 5: "XPUM_RENDER",
        0x7fffffff:"XPUM_TYPE_FLAGS_FORCE_UINT32",
    }.get(num, "unknown")

def search_mode_enumList(num):
    nameList = []
    if num >= 0x7fffffff:
        nameList.append('XPUM_MODE_FORCE_UINT32');
        num -= 0x7fffffff
    if num >= 3:
        nameList.append('XPUM_COMPUTE_UNIT_DEBUG')
        num -= 3
    if num >= 2:
        nameList.append('XPUM_EXCLUSIVE')
        num -= 2
    if num >= 1:
        nameList.append('XPUM_TIMESLICE')
        num -= 1
    if num >= 0:
        nameList.append('XPUM_TIMEOUT')
        num -= 0
    return nameList

def search_mode_enum(num):
    nameList = []
    if num >= 0x7fffffff:
        nameList.append('XPUM_MODE_FORCE_UINT32');
        return nameList
    if num >= 3:
        nameList.append('XPUM_COMPUTE_UNIT_DEBUG')
        return nameList
    if num >= 2:
        nameList.append('XPUM_EXCLUSIVE')
        return nameList
    if num >= 1:
        nameList.append('XPUM_TIMESLICE')
        return nameList
    if num >= 0:
        nameList.append('XPUM_TIMEOUT')
        return nameList
    return nameList

