def get_diag_rows(data):
    header_row = ["Device Id", data['DeviceId']]
    base_row_keys = ["Level", "Finished", "Count", "Message"]
    base_row_values = [str(data['Level']), str(data['Finished']), str(data['Count']), data['Message']]
    base_row = ["\n".join(base_row_keys),"\n".join(base_row_values)]
    rows = []
    for component in data['ComponentList']:
        v = "Finished: {}\nResult: {}\nMessage: {}".format(
                component["Finished"],
                component["Result"],
                component["Message"]
        )
        rows.append([component["Type"],v])
    return [header_row, base_row, *rows]

def run_device_diagnostics(deviceId, level):
    reqData = {
        "DiagnosticsLevel":level
    }
    res = requests.post(host+"/rest/v1/devices/{}/diagnostics".format(deviceId), json=reqData)
    if res.status_code != 200:
        print("Error occurs:"+res.content.decode())
        return
    while True:
        res = requests.get(host+"/rest/v1/devices/{}/diagnostics".format(deviceId))
        if res.status_code != 200:
            print("Error occurs:"+res.content.decode())
            return
        data = res.json()
