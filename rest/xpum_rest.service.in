[Unit]
Description=XPUM_Rest daemon

After=xpum.target

[Service]
Type=simple
RemainAfterExit=yes

RuntimeDirectory=xpum

WorkingDirectory=@CPACK_PACKAGING_INSTALL_PREFIX@/rest/

ExecStart=gunicorn --certfile cert.pem --keyfile key.pem --bind 0.0.0.0:30000 --worker-class gevent --worker-connections 1000 -w 3 --ciphers "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES128-GCM-SHA256" xpum_rest_main:app
ExecStop=/bin/kill -s TERM $MAINPID
ExecReload=/bin/kill -s HUP $MAINPID

User=xpum

[Install]
WantedBy=multi-user.target
