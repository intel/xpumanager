[Unit]
Description=XPUM-Rest daemon

After=xpum.target

[Service]
Type=oneshot
RemainAfterExit=yes

ExecStart=@CPACK_PACKAGING_INSTALL_PREFIX@/rest/xpum_rest.sh start
ExecStop=@CPACK_PACKAGING_INSTALL_PREFIX@/rest/xpum_rest.sh stop
ExecReload=@CPACK_PACKAGING_INSTALL_PREFIX@/rest/xpum_rest.sh reload

[Install]
WantedBy=multi-user.target
