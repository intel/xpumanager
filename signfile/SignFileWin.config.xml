<?xml version="1.0" standalone="no" ?>
<configuration>
	<appSettings>
		<add key="VerboseMode" value="Moderate"/>
		<!-- <add key="PgpPublicKeyFileName" value="intelswprod.public" /> -->
		<add key="DefaultCertificateName" value="intel_xpum_windows_ext_s1"/>
    <!-- Additional requirements (base64 encoded) for Mac OS signing 
    The MacServerRequirements value below should only be specified when using the Apple Certificate for signing.
    If you are using an Intel issued internal/external certificate then please do not specify this value 
    instead use : 
    <add key="MacServerRequirements" value=""/>
    -->
		<add key="MacServerRequirements" value="+t4MAQAAACQAAAABAAAAAwAAABT63gwAAAAAEAAAAAEAAAAP"/>
		<!-- Path to cross certificate for windows kernel mode driver signing (or if using the -a commandline option). The cross certificates for sha2 and sha1 certificates are available to download at the release location  
		Use the sha2-cross.crt for sha2 certificates 
		Use the sha1-cross.crt for sha1 certificates
		--> 
		<add key="CrossCertificateFile" value="" />
		<!-- Directory where cached  directories + files should be stored. The user running the utility should have access to created directories and files at this location.
		If left empty the directories + files will be stored in the working directory. --> 
		<add key="CacheFilesLocation" value=""/>
		<!-- If set to True will disable the caching of local certificate/template files. Note that this will hamper performance.--> 
		<add key="DisableCache" value="False" />
		<!-- If set to True will disable the sending of email notification in case a signing error occurs.--> 
		<add key="DisableErrorEmail" value="False" />
		
		<add key="WebServiceURL" value="https://edss-next-api.intel.com;"/>
		
		<add key="AuthenticationServer" value="https://iamws-i.intel.com/api/v1"/>
		<!--<add key="UserName" value="amr\swfactory"/>
		<add key="Password" value=""/>-->
		<add key="SoapRequestAttempts" value="3"/>
		<add key="DelayBetweenRequestAttempts" value="30"/>
		<add key="SoapRequestTimeout" value="180"/>
		<add key="SkipSignedFiles" value="False"/>
		<add key="WorkingThreads" value="Auto"/>
		<add key="DisableTimestamping" value="False"/>
		<!-- <add key="SupportBigEndian" value="True" /> -->
		<!-- <add key="Description" value="" /> -->
		<!-- <add key="DescriptionUrl" value="" /> -->
		<!-- <add key="Identifier" value="" /> -->
		<!-- <add key="OptionFlags" value="" /> -->
		<!-- <add key="LocalBuffer" value="" /> -->
		<!-- <add key="FileWithRequirements" value="" /> -->
		<!-- <add key="Entitlements" value="" /> -->
		<!-- <add key="PageSize" value="" /> -->
		<!-- <add key="ApplicationRulesFileName" value="" /> -->
		<add key="LogFileName" value="Log.txt"/>
		<!-- <add key="UseAdditionalCertificate" value="True" /> -->
		<add key="AlwaysSignKernelDriversWithAdditionalCertificate" value="False"/>
		<add key="HashAlgorithm" value="SHA256"/>

    <add key="SimpleWFAttempts" value="250"/>
    <add key="DelayBetweenSimpleWFAttempts" value="15"/>
	<!-- <add key="NvmBigEndian" value="False" /> -->
    
    <!--
    TimeStampServiceURL format multiple server entries separated by ;   
    Each server entry has the following format :  URL|OS1,OS2|Standard|IsExternal
    
    eg.  
    "http://timestamp.intel.com/TSS/AuthenticodeTS|Windows|Authenticode|0;http://timestamp.intel.com/TSS/HttpTspServer|Windows,Linux|rfc_3161|0"
    
    Windows
		MacOS
		Linux
		CrossPlatform
		FreeBSD
    -->

    <add key="TimeStampServiceURL" value="http://timestamp.apple.com/ts01|MacOS|rfc_3161|1;http://timestamp.intel.com/TSS/AuthenticodeTS|Windows|AuthentiCode|0;http://timestamp.intel.com/TSS/HttpTspServer|Linux,Windows|rfc_3161|0;http://timestamp.verisign.com/scripts/timestamp.dll|Windows|Authenticode|1;http://timestamp.comodoca.com|Linux,Windows|rfc_3161|1"/>
	<!-- 
			The Time Stamp Hash algorithm that should be used if timestamping is enabled. For Windows + SHA1 an Authenticode TimeStamp Authority should be configured in the TimeStampServiceURL above
		-->
	<add key="TimeStampHashAlgorithm" value="SHA256"/>
    <add key="TimeStampRetries" value="15" />
    <add key="TimeStampDelaySeconds" value="45" />
	<!-- 
	If an external timestamp server has to be used then this proxy setting will be used. The machine doing the signing should have access to the proxy server and its port (911) in order to get out to external time stamp servers 
	for e.g. http://timestamp.apple.com/ts01  http://timestamp.verisign.com/scripts/timestamp.dll
	-->
    <add key="HttpProxy" value="proxy-chain.intel.com:911" />
	</appSettings>
</configuration>
