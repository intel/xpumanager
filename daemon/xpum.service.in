[Unit]
Description=XPUM daemon

After=syslog.target

[Service]
Type=simple

Environment="LD_LIBRARY_PATH=/usr/local/xpum:/$LD_LIBRARY_PATH"

#ExecStartPre=rm -rf /tmp/xpum.sock

ExecStart=@CPACK_PACKAGING_INSTALL_PREFIX@/bin/xpumd  --pid_file /var/xpum_daemon.pid --socket_file /tmp/xpum.sock

ExecStop=/bin/kill -TERM $MAINPID

[Install]
WantedBy=multi-user.target