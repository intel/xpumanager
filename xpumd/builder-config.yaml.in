dist:
  module: github.com/intel/xpumanager/xpumd
  name: xpumd
  description: XPUM Daemon
  output_path: ./dist
  otelcol_version: @OTEL_VERSION@
  version: 0.0.0
  # Enable CGO explicitly, as we are linking against external library
  # Ref: https://github.com/open-telemetry/opentelemetry-collector/tree/main/cmd/builder#cgo-disabled-by-default
  cgo_enabled: true

replaces:
  - github.com/intel/level-zero-go => ../level-zero-go
  - github.com/intel/xpumanager/xpumd => ../
  - github.com/intel/xpumanager/xpumd/common => ../common

exporters:
  - gomod: go.opentelemetry.io/collector/exporter/otlpexporter v@OTEL_VERSION@
  - gomod: go.opentelemetry.io/collector/exporter/otlphttpexporter v@OTEL_VERSION@
  - gomod: github.com/open-telemetry/opentelemetry-collector-contrib/exporter/prometheusexporter v@OTEL_VERSION@
  - gomod: github.com/intel/xpumanager/xpumd/exporter/intelxpuinfo v0.0.0
    path: ./exporter/intelxpuinfo
    name: intelxpuinfoexporter

receivers:
  - gomod: github.com/intel/xpumanager/xpumd/receiver/intelxpu v0.0.0
    path: ./receiver/intelxpu
    name: intelxpureceiver

processors:
  - gomod: github.com/intel/xpumanager/xpumd/processor/intelxpustatus v0.0.0
    path: ./processor/intelxpustatus
    name: intelxpustatus

extensions:
