.PHONY : src/monitor/monitor_task.cpp.o

src/monitor/monitor_task.i: src/monitor/monitor_task.cpp.i

.PHONY : src/monitor/monitor_task.i

# target to preprocess a source file
src/monitor/monitor_task.cpp.i:
	$(MAKE) -f CMakeFiles/DGMCore.dir/build.make CMakeFiles/DGMCore.dir/src/monitor/monitor_task.cpp.i
.PHONY : src/monitor/monitor_task.cpp.i

src/monitor/monitor_task.s: src/monitor/monitor_task.cpp.s

.PHONY : src/monitor/monitor_task.s

# target to generate assembly for a file
src/monitor/monitor_task.cpp.s:
	$(MAKE) -f CMakeFiles/DGMCore.dir/build.make CMakeFiles/DGMCore.dir/src/monitor/monitor_task.cpp.s
.PHONY : src/monitor/monitor_task.cpp.s

