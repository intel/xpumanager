def STATUS_COLOR_MAP = [
  'SUCCESS': '#78b037', 
  'FAILURE': '#d54c53', 
  'UNSTABLE': '#f5a623', 
  'ABORTED': '#949393']

def buildPropertyFile = 'build.props'

def createEnvironmentVariablesFile(){
  def commit = sh(returnStdout: true, script: 'git rev-parse HEAD').trim()
  def now = new Date()
  def properties = [
    'BUILD_TIMESTAMP': now.format("yyyyMMdd.HHmmss"),
    'BUILD_DATE': now.format("yyyyMMdd"),
    'BUILD_TIME': now.format("HHmmss"),
    'GIT_COMMIT': commit,
    'GIT_COMMIT_SHORT': commit.take(8),
    'DOCKER_IMG_TAG': now.format("yyyyMMdd.HHmmss") + 'i-' + commit.take(8)
  ]

  writeYaml file:'build.props', data: properties
}

def loadEnvironmentVariables() {
  def props = readYaml file: 'build.props'
  keys= props.keySet()
  for(key in keys) {
      value = props["${key}"]
      env."${key}" = "${value}"
  }
}

pipeline {
    parameters { 
      string(name: 'PUBLISH_DOCKER_REGISTRY', defaultValue: 'amr-registry.caas.intel.com/dms-pub', description: 'the docker registry for publishing the xpum image') 
      string(name: 'K8S_CLUSTER', defaultValue: 'amr-compute-cluster', description: 'the k8s cluster providing build agents')
    }
    options {
        buildDiscarder(logRotator(numToKeepStr: '20', artifactNumToKeepStr: '20'))
        timeout(time: 60, unit: 'MINUTES')
        skipStagesAfterUnstable()
        disableConcurrentBuilds()
        timestamps()
    }
    agent {
      kubernetes {
        cloud "${params.K8S_CLUSTER}"
        yaml getPodYaml()
      }
    }
    environment {
      WEBHOOK_URL = 'https://intel.webhook.office.com/webhookb2/df60700c-6bcb-46de-9a4a-d5f324db9f11@46c98d88-e344-4ed4-8496-4ed7712e255d/IncomingWebhook/0d756f8858c241ed8f219df29410a4d0/0f689104-5007-497d-ab31-8663e5b0238e'
      ARCHIVE_FILES = 'build-deb/*.deb,build-centos*/*.rpm,build-sles/*.rpm,XPUM_PGP_KEY.pem'
      PUBLISH_DOCKER_REGISTRY = "${params.PUBLISH_DOCKER_REGISTRY}"
    }
    stages {
      stage('Prepare') {
          steps {

            container(name: 'jnlp', shell: 'bash') {
              script {
                createEnvironmentVariablesFile()
                loadEnvironmentVariables()
              }
            }
          }
      } 
      stage('Build') {
        parallel {
          stage('ubuntu deb') {
            steps {
              container(name: 'xpum-builder-ubuntu') {
                script {
                  loadEnvironmentVariables()
                }
                sh '''
                  env && MAIN_WORKSPACE=$PWD && \
                  mkdir ../ws_ubuntu && \
                  cp -rp . ../ws_ubuntu && \
                  cd ../ws_ubuntu && \
                  export CCACHE_DIR=/home/jenkins/jenkins-shared-pvc/ws_ubuntu && \
                  export CCACHE_BASEDIR=$PWD && \
                  mkdir -p $CCACHE_DIR && \
                  ./build.sh -DBUILD_DOC=ON -DBUILD_DATE=$BUILD_DATE -DBUILD_TIME=$BUILD_TIME -DGIT_COMMIT=$GIT_COMMIT_SHORT \
                    -DCMAKE_C_COMPILER_LAUNCHER=ccache \
                    -DCMAKE_CXX_COMPILER_LAUNCHER=ccache && \
                  mkdir $MAIN_WORKSPACE/build-deb && \
                  cp ./build/xpum*.deb $MAIN_WORKSPACE/build-deb
                '''
              }
            }
          }

          stage('centos-7 rpm') {
            steps {
              container(name: 'xpum-builder-centos7', shell: 'bash') {
                script {
                  loadEnvironmentVariables()
                }
                sh '''
                  env && MAIN_WORKSPACE=$PWD && \
                  mkdir ../ws_centos7 && \
                  cp -rp . ../ws_centos7 && \
                  cd ../ws_centos7 && \
                  export CCACHE_DIR=/home/jenkins/jenkins-shared-pvc/ws_centos7 && \
                  export CCACHE_BASEDIR=$PWD && \
                  mkdir -p $CCACHE_DIR && \
                  ./build.sh -DBUILD_DOC=ON -DBUILD_DATE=$BUILD_DATE -DBUILD_TIME=$BUILD_TIME -DGIT_COMMIT=$GIT_COMMIT_SHORT \
                    -DCMAKE_C_COMPILER_LAUNCHER=ccache \
                    -DCMAKE_CXX_COMPILER_LAUNCHER=ccache && \
                  mkdir $MAIN_WORKSPACE/build-centos7 && \
                  cp ./build/xpum*.rpm $MAIN_WORKSPACE/build-centos7
                '''
              }
            }
          }

          stage('centos-8 rpm') {
            steps {
              container(name: 'xpum-builder-centos8', shell: 'bash') {
                script {
                  loadEnvironmentVariables()
                }
                sh '''
                  env && MAIN_WORKSPACE=$PWD && \
                  mkdir ../ws_centos8 && \
                  cp -rp . ../ws_centos8 && \
                  cd ../ws_centos8 && \
                  export CCACHE_DIR=/home/jenkins/jenkins-shared-pvc/ws_centos8 && \
                  export CCACHE_BASEDIR=$PWD && \
                  mkdir -p $CCACHE_DIR && \
                  ./build.sh -DBUILD_DOC=ON -DBUILD_DATE=$BUILD_DATE -DBUILD_TIME=$BUILD_TIME -DGIT_COMMIT=$GIT_COMMIT_SHORT \
                    -DCMAKE_C_COMPILER_LAUNCHER=ccache \
                    -DCMAKE_CXX_COMPILER_LAUNCHER=ccache && \
                  mkdir $MAIN_WORKSPACE/build-centos8 && \
                  cp ./build/xpum*.rpm $MAIN_WORKSPACE/build-centos8
                '''
              }
            }
          }

          stage('suse rpm') {
            steps {
              container(name: 'xpum-builder-sles', shell: 'bash') {
                script {
                  loadEnvironmentVariables()
                }
                sh '''
                  env && MAIN_WORKSPACE=$PWD && \
                  mkdir ../ws_sles && \
                  cp -rp . ../ws_sles && \
                  cd ../ws_sles && \
                  export CCACHE_DIR=/home/jenkins/jenkins-shared-pvc/ws_sles && \
                  export CCACHE_BASEDIR=$PWD && \
                  mkdir -p $CCACHE_DIR && \
                  ./build.sh -DBUILD_DOC=ON -DBUILD_DATE=$BUILD_DATE -DBUILD_TIME=$BUILD_TIME -DGIT_COMMIT=$GIT_COMMIT_SHORT \
                    -DCMAKE_C_COMPILER_LAUNCHER=ccache \
                    -DCMAKE_CXX_COMPILER_LAUNCHER=ccache && \
                  mkdir $MAIN_WORKSPACE/build-sles && \
                  cp ./build/xpum*.rpm $MAIN_WORKSPACE/build-sles
                '''
              }
            }
          }
        }
      }

      stage('Publish') {
        parallel {
          stage('Create Docker Image') {
            steps {
              container(name: 'kaniko') { 
                script {
                  loadEnvironmentVariables()
                }
                sh '''
                  pwd && env && \
                  cp rest/requirements.txt deployment/docker && \
                  cp third-party-programs.txt deployment/docker && \
                  mkdir deployment/docker/build-deb && cp build-deb/xpum*.deb deployment/docker/build-deb && \
                  export http_proxy=http://proxy-dmz.intel.com:911 && \
                  export HTTP_PROXY=http://proxy-dmz.intel.com:911 && \
                  export https_proxy=http://proxy-dmz.intel.com:912 && \
                  export HTTPS_PROXY=http://proxy-dmz.intel.com:912 && \
                  export no_proxy=.intel.com && \
                  export NO_PROXY=.intel.com && \
                  /kaniko/executor \
                    --cache=true \
                    --build-arg http_proxy=http://proxy-dmz.intel.com:911 \
                    --build-arg HTTP_PROXY=http://proxy-dmz.intel.com:911 \
                    --build-arg https_proxy=http://proxy-dmz.intel.com:912 \
                    --build-arg HTTPS_PROXY=http://proxy-dmz.intel.com:912 \
                    --build-arg no_proxy=.intel.com \
                    --build-arg NO_PROXY=.intel.com \
                    --dockerfile `pwd`/deployment/docker/Dockerfile.ubuntu \
                    --context `pwd`/deployment/docker \
                    --skip-tls-verify \
                    --destination=$PUBLISH_DOCKER_REGISTRY/xpumanager-kaniko:$DOCKER_IMG_TAG
                '''
              }
            }
          }

          stage('Archive') {
            steps {
              archiveArtifacts(artifacts: "${env.ARCHIVE_FILES}", fingerprint: true, onlyIfSuccessful: true)
            }
          }

          stage('Upload artifact') {
            steps{
                script {
                  loadEnvironmentVariables()
                }
                rtServer (
                    id: 'AF-XPUM',
                    url: 'https://ubit-artifactory-sh.intel.com/artifactory/',
                    // If you're using Credentials ID:
                    credentialsId: 'sys-dcm-crdentials',
                    // If Jenkins is configured to use an http proxy, you can bypass the proxy when using this Artifactory server:
                    bypassProxy: true,
                    // Configure the connection timeout (in seconds).
                    // The default value (if not configured) is 300 seconds
                    timeout: 300
                )
                rtUpload(
                    serverId: 'AF-XPUM',
                    spec: '''{
                      "files": [
                        {
                          "pattern": "build-*/*.*",
                          "target": "xpumanager-sh-local/$JOB_NAME/$BUILD_TIMESTAMP.$GIT_COMMIT_SHORT/",
                          "props": "retention.days=720;mytest=true"
                        },
                        {
                          "pattern": "XPUM_PGP_KEY.pem",
                          "target": "xpumanager-sh-local/$JOB_NAME/$BUILD_TIMESTAMP.$GIT_COMMIT_SHORT/",
                          "props": "retention.days=720;mytest=true"
                        }
                      ]
                    }''',
                    "failNoOp": true
                )
            }
          }
        }
      }
    }
